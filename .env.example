# Copie para `.env.local` na raiz do projeto (não commite segredos).
# Supabase: Project Settings → API → Project URL e anon/public key.

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Specs de pneus: catálogo local (src/app/data/tireSpecsCatalog.ts) — sem API externa.

# Opcional: URI do Postgres para `npm run db:migrate`
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[SENHA]@....pooler.supabase.com:6543/postgres
